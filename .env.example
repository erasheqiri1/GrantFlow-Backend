
# development → /docs dhe /redoc aktive
# production  → /docs dhe /redoc çaktivizohen (404)
ENV=development

# DATABASE
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/grantflow

# Gjenero me: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=vendos-nje-string-te-gjate-random

# Access token: sa minuta deri sa skadon (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token: sa ditë deri sa skadon (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# REDIS (rate limiting + token blacklist)
REDIS_URL=redis://localhost:6379/0

# AI
GROQ_API_KEY=gsk-...

# SUPER ADMIN (krijohet automatikisht me seed)
SUPER_ADMIN_EMAIL=your-email@example.com
SUPER_ADMIN_PASSWORD=your-strong-password-here

# EMAIL (Gmail SMTP)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com

# FRONTEND
# Development:  http://localhost:3000
# Production:   https://domain-yt.com
FRONTEND_URL=http://localhost:3000
